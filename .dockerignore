# Secrets and local state
.env
.env.local
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# Node / Python build artifacts (rebuilt inside the image)
**/node_modules
**/__pycache__
**/*.pyc
.venv/
venv/
backend/venv/
backend/.venv/

